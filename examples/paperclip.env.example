# Core runtime paths
PAPERCLIP_REAL_KIMI=/usr/local/bin/kimi
PAPERCLIP_HOME=/var/lib/paperclip
PAPERCLIP_WRAPPER_STATE_DIR=/var/lib/paperclip/wrapper-state-kimi
PAPERCLIP_KIMI_SESSIONS_DIR=/var/lib/paperclip/.kimi/sessions

# Optional debug prompt dumps
PAPERCLIP_WRAPPER_DEBUG_PROMPT=0

# Optional strict issue-sync validation
PAPERCLIP_VALIDATE_ISSUE_SYNC=0
PAPERCLIP_VALIDATE_ISSUE_SYNC_MODE=db

# Optional DB source used by validation mode
PAPERCLIP_ENV_FILE=/etc/paperclip/paperclip.env
# DATABASE_URL=postgres://paperclip_app@127.0.0.1:5432/paperclip
